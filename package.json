{
  "name": "billory",
  "version": "0.1.0",
  "description": "Rechnungs- und Angebotssoftware für Baum Performance Stahl",
  "main": "src/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eklipsee/billory.git"
  },
  "author": "Daniel Schitz",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "build": {
    "appId": "de.billory.app",
    "productName": "Billory",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/main/backend/backend.jar",
        "to": "backend/backend.jar"
      },
      {
        "from": "runtime",
        "to": "runtime"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Billory"
    }
  }
}
